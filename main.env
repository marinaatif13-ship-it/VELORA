# Server
PORT=5000
NODE_ENV=development

# Database
MONGODB_URI=mongodb://localhost:27017/velora

# JWT
JWT_SECRET=velora_super_secret_jwt_key_2026
JWT_EXPIRE=30d

# Cloudinary (for image upload)
CLOUDINARY_CLOUD_NAME=your_cloud_name
